{
  "name": "@fd/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "prisma generate",
    "db:generate": "prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@fd/config": "workspace:*",
    "@pothos/plugin-prisma": "^4.14.3",
    "@types/pg": "^8.15.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^8.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
