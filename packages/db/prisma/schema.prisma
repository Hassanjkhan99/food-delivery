// ───────────────────────────── support, audit, misc ─────────────────────────────

model SupportTicket {
  id             String       @id @default(cuid())
  customerId     String
  orderId        String?
  category       String
  subject        String
  body           String
  status         TicketStatus @default(open)
  resolutionCode String?
  // Agent queue ownership + SLA tracking (#14; agent stored by id + name
  // snapshot to avoid a second User relation on this model). Additive.
  assignedToUserId String?
  assignedToName   String?
  firstRespondedAt DateTime?  @db.Timestamptz()
  resolvedAt       DateTime?  @db.Timestamptz()
  // Customer-visible resolution note surfaced on the ticket thread, e.g.
  // "Refund of Rs 350 approved to your wallet". Written by admin/support on
  // resolve; null until then. Shared by #14 + #45. Additive.
  resolutionNote   String?
  // Structured intake payload for the category (e.g. the ids/names of the order
  // items a missing/wrong-items complaint is about) so support/admin sees
  // actionable data and the refund workbench can prefill amounts. (#45) Additive.
  contextJson      Json?
  // Refund opened by this ticket (missing/wrong items), if any. Lets the customer
  // see the resolution and the workbench trace it back. (#45) Additive.
  refundId         String?
  createdAt      DateTime     @default(now()) @db.Timestamptz()
  updatedAt      DateTime     @updatedAt @db.Timestamptz()

  customer User    @relation(fields: [customerId], references: [id])
  order    Order?  @relation(fields: [orderId], references: [id])
  refund   Refund? @relation(fields: [refundId], references: [id])

  @@index([status])
  @@index([status, createdAt])
  // Order-help view lists a customer's tickets for one order, newest first
  // (help.ts ticketsForOrder). Serve that access pattern from the index instead
  // of scanning as ticket volume grows. (#45)
  @@index([customerId, orderId, createdAt])
  @@map("support_tickets")
}

model Rating {
  id               String           @id @default(cuid())
  orderId          String           @unique
  customerId       String
  restaurantId     String
  stars            Int
  tags             String[]         @default([])
  comment          String?
  moderationStatus ModerationStatus @default(approved)
  createdAt        DateTime         @default(now()) @db.Timestamptz()

  order      Order      @relation(fields: [orderId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
  @@map("ratings")
}

// Append-only audit trail for privileged actions.
model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorRole   String?
  action      String
  subjectType String
  subjectId   String
  beforeJson  Json?
  afterJson   Json?
  ip          String?
  createdAt   DateTime @default(now()) @db.Timestamptz()

  @@index([subjectType, subjectId])
  @@index([createdAt])
  @@map("audit_logs")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  keysJson  Json
  createdAt DateTime @default(now()) @db.Timestamptz()

  user User @relation(fields: [userId], references: [id])

  @@map("push_subscriptions")
}

// Backlog: promoted deals. Schema only — no UI in MVP.
model Campaign {
  id               String         @id @default(cuid())
  restaurantId     String
  type             CampaignType
  status           CampaignStatus @default(draft)
  dailyRateMinor   Int
  startsAt         DateTime?      @db.Timestamptz()
  endsAt           DateTime?      @db.Timestamptz()
  approvedByUserId String?
  // Promoted deals (#22) additions:
  //  - label: short copy shown on the deal badge / featured slot (e.g. "20% off").
  //  - approvedAt/rejectedReason: audited admin decision metadata.
  //  - lastAccruedAt: date (UTC midnight) the daily fee was last debited, so the
  //    accrual job is idempotent and never double-charges a running campaign.
  label            String?
  approvedAt       DateTime?      @db.Timestamptz()
  rejectedReason   String?
  lastAccruedAt    DateTime?      @db.Timestamptz()
  createdAt        DateTime       @default(now()) @db.Timestamptz()

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
  @@index([status])
  @@map("campaigns")
}

// In-app notification / offers inbox (#56). One row per customer-visible message:
// order-lifecycle updates (transactional, deep-link to the order) and admin promo
// blasts (promo, deep-link to a restaurant/voucher). Read state is per-row (readAt).
// This is the in-app companion to the #13 delivery pipeline (WhatsApp/push/SMS);
// rows here are what the bell + inbox render after the fact.
model Notification {
  id           String           @id @default(cuid())
  userId       String
  kind         NotificationKind @default(transactional)
  title        String
  body         String
  // Client-side deep link (e.g. /orders/{id} or /r/{slug}). Optional; the inbox
  // renders a plain entry when absent.
  linkHref     String?
  // Soft references for context/filtering. Not FKs so a row can outlive the subject
  // and creation stays non-fatal even if the id is stale.
  orderId      String?
  restaurantId String?
  readAt       DateTime?        @db.Timestamptz()
  createdAt    DateTime         @default(now()) @db.Timestamptz()

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("notifications")
}

// Delivery-area waitlist (#64): captures "notify me" sign-ups from areas we don't
// serve yet. Upserted by email so re-submitting just refreshes the pin/area.
model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  areaLabel String?
  lat       Decimal? @db.Decimal(9, 6)
  lng       Decimal? @db.Decimal(9, 6)
  createdAt DateTime @default(now()) @db.Timestamptz()

  @@map("waitlist")
}

// ───────────────────────────── vouchers / promo codes (#52) ─────────────────────────────

// A redeemable promo code. Validation (window, min-order, per-user + total-budget caps,
// scope, first-order) all lives in voucherService — the single source of truth used by
// both quote and placeOrder. Money is minor units; percentage discounts use valueBps
// (850 = 8.5%) capped by maxDiscountMinor. usedCount is a denormalised counter kept in
// sync with VoucherRedemption inside the placeOrder transaction (source of truth is the
// redemption rows). A restaurant-scoped voucher only applies to orders at that restaurant.
model Voucher {
  id               String        @id @default(cuid())
  code             String        @unique
  description      String?
  type             VoucherType
  scope            VoucherScope  @default(platform)
  funder           VoucherFunder @default(platform)
  // percentage → valueBps (+ optional maxDiscountMinor cap); fixed → valueMinor;
  // free_delivery → neither (waives the order's delivery fee).
  valueBps         Int           @default(0)
  valueMinor       Int           @default(0)
  maxDiscountMinor Int?
  minOrderMinor    Int           @default(0)
  // Eligibility / limits. firstOrderOnly restricts to a customer's first delivered/placed
  // order. perUserLimit caps redemptions per user (null = unlimited). totalBudgetMinor caps
  // cumulative discount spend across all users (null = unbudgeted); usedBudgetMinor tracks it.
  firstOrderOnly   Boolean       @default(false)
  perUserLimit     Int?          @default(1)
  totalBudgetMinor Int?
  usedBudgetMinor  Int           @default(0)
  usedCount        Int           @default(0)
  // Restaurant-scoped vouchers only apply at this restaurant (null when scope=platform).
  restaurantId     String?
  startsAt         DateTime?     @db.Timestamptz()
  endsAt           DateTime?     @db.Timestamptz()
  active           Boolean       @default(true)
  createdByUserId  String?
  createdAt        DateTime      @default(now()) @db.Timestamptz()
  updatedAt        DateTime      @updatedAt @db.Timestamptz()

  restaurant  Restaurant?         @relation(fields: [restaurantId], references: [id])
  redemptions VoucherRedemption[]
  orders      Order[]

  @@index([code])
  @@map("vouchers")
}

// One row per successful redemption. unique(voucherId, orderId) makes double-apply on the
// same order impossible; the per-user count is derived by counting rows for (voucherId, userId).
// reversedAt is set when the order is cancelled/refunded so the redemption no longer counts
// against the user's limit or the total budget.
model VoucherRedemption {
  id          String    @id @default(cuid())
  voucherId   String
  orderId     String    @unique
  userId      String
  amountMinor Int
  reversedAt  DateTime? @db.Timestamptz()
  createdAt   DateTime  @default(now()) @db.Timestamptz()

  voucher Voucher @relation(fields: [voucherId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])

  @@unique([voucherId, orderId])
  @@index([voucherId, userId])
  @@map("voucher_redemptions")
}
