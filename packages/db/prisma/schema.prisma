// Food Delivery — full domain schema (M1).
// Conventions: cuid() string PKs, timestamptz timestamps, money as Int minor units (paisa).
// Append-only tables (OrderEvent, DeliveryEvent, LedgerEntry, AuditLog) have no
// update/delete paths in app code. Menu publish clones the draft into a new immutable
// version; OrderItem freezes a menuSnapshotJson so orders never depend on live menus.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator pothos {
  provider     = "prisma-pothos-types"
  clientOutput = "./prisma/client.js"
  output       = "../src/generated/pothos-types.ts"
}

datasource db {
  provider = "postgresql"
}

// ───────────────────────────── enums ─────────────────────────────

enum Role {
  customer
  restaurant_owner
  restaurant_staff
  rider
  admin
}

enum RestaurantStatus {
  pending_approval
  approved
  suspended
}

enum RestaurantTier {
  small_business
  chain
}

enum MenuStatus {
  draft
  published
  archived
}

enum MenuSourceKind {
  photo
  pdf
  csv
}

enum MenuSourceStatus {
  uploaded
  transcribed
}

enum CardStyle {
  flat
  tilt3d
  glass
}

enum HeroEffect {
  none
  parallax
  depth
}

enum RiderType {
  restaurant
  shared
  independent
}

enum RiderVerification {
  pending
  verified
  rejected
}

enum OrderStatus {
  pending_acceptance
  accepted
  rejected
  auto_expired
  preparing
  ready_for_pickup
  rider_assigned
  reassigning
  picked_up
  out_for_delivery
  delivered
  failed_delivery_attempt
  cancelled
}

enum DeliveryTaskStatus {
  unassigned
  // Offer→accept flow (swipe-to-accept): a task dispatched to a rider awaiting their
  // acceptance. Additive — the legacy path still assigns directly to `assigned`, so
  // `offered` only appears for tasks created via the new offer flow.
  offered
  assigned
  arrived_pickup
  picked_up
  delivered
  failed
}

enum DeliveryEventType {
  // Additive offer-flow events (see DeliveryTaskStatus.offered).
  offered
  accepted
  declined
  assigned
  arrived_pickup
  picked_up
  delivered
  failed
  incident
}

// Lifecycle of a shared-rider DeliveryOffer (#21). An offer is the artifact the dispatch
// engine emits to a candidate rider (separate from the DeliveryTask/Order). It is `pending`
// until the rider accepts (`accepted` — which locks the task) or lets it lapse (`declined`
// on explicit reject, `expired` once expiresAt passes). Only one offer per task may reach
// `accepted`; the accept path enforces the lock. Additive.
enum DeliveryOfferStatus {
  pending
  accepted
  declined
  expired
  withdrawn
}

enum PaymentMode {
  cod
  card
  wallet
}

// How the customer receives the order. `delivery` is the default (rider brings it);
// `pickup` means the customer collects at the branch — no rider, no delivery fee, a
// pickup code instead of tracking. See Order.fulfillmentMode (#54).
enum FulfillmentMode {
  delivery
  pickup
}

enum PaymentStatus {
  pending
  authorized
  captured
  refunded
  partially_refunded
  failed
}

enum RefundStatus {
  refund_pending
  refunded
  refund_rejected
}

enum RefundDestination {
  card
  wallet
}

enum PayoutStatus {
  pending
  paid
  failed
}

enum LedgerOwnerType {
  platform
  restaurant
  customer
  rider
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum ModerationStatus {
  pending
  approved
  rejected
}

enum MediaAssetStatus {
  pending
  finalized
}

enum CampaignType {
  featured_slot
  deal_badge
}

// In-app notification/offers inbox (#56). `transactional` covers order lifecycle
// updates (always delivered, never opt-outable); `promo` covers admin-composed
// marketing blasts (suppressed when User.marketingOptOut is set).
enum NotificationKind {
  transactional
  promo
}

enum CampaignStatus {
  draft
  pending_approval
  active
  ended
  rejected
}

// Promo-code engine (#52). A voucher's discount is either a percentage (valueBps,
// optionally capped by maxDiscountMinor) or a flat amount (valueMinor), or free
// delivery (waives the order's deliveryFeeMinor). funder decides which ledger legs
// the discount reverses on settlement: platform absorbs it as marketing spend,
// restaurant absorbs it out of its payable, or split proportionally.
enum VoucherType {
  percentage
  fixed
  free_delivery
}

enum VoucherScope {
  platform
  restaurant
}

enum VoucherFunder {
  platform
  restaurant
  split
}

// ───────────────────────────── identity & auth ─────────────────────────────

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String?
  email     String?
  // Marketing opt-out (#56). When true, promo inbox entries are suppressed for this
  // user; transactional order updates are always delivered regardless.
  marketingOptOut Boolean @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  roles            UserRole[]
  sessions         Session[]
  addresses        Address[]
  ordersPlaced     Order[]             @relation("CustomerOrders")
  paymentMethods   PaymentMethod[]
  rider            Rider?
  ownedRestaurants Restaurant[]        @relation("RestaurantOwner")
  tickets          SupportTicket[]
  pushSubs         PushSubscription[]
  notifications    Notification[]

  @@map("users")
}

model UserRole {
  id           String  @id @default(cuid())
  userId       String
  role         Role
  restaurantId String?

  user       User        @relation(fields: [userId], references: [id])
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id])

  @@unique([userId, role, restaurantId])
  @@index([userId])
  @@map("user_roles")
}

model OtpCode {
  id         String    @id @default(cuid())
  phone      String
  codeHash   String
  expiresAt  DateTime  @db.Timestamptz()
  consumedAt DateTime? @db.Timestamptz()
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now()) @db.Timestamptz()

  @@index([phone, createdAt])
  @@map("otp_codes")
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  expiresAt DateTime  @db.Timestamptz()
  revokedAt DateTime? @db.Timestamptz()
  userAgent String?
  createdAt DateTime  @default(now()) @db.Timestamptz()

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("sessions")
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String
  text      String
  lat       Decimal  @db.Decimal(9, 6)
  lng       Decimal  @db.Decimal(9, 6)
  phone     String?
  notes     String?
  // Customer's preferred address, pre-selected at checkout. At most one per user is
  // true — enforced in app code (setAddress/saveAddress clear the others in a tx).
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz()

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("addresses")
}

// ───────────────────────────── restaurants & branches ─────────────────────────────

model Restaurant {
  id        String           @id @default(cuid())
  name      String
  slug      String           @unique
  status    RestaurantStatus @default(pending_approval)
  tier      RestaurantTier   @default(small_business)
  ownerId   String
  // Curated platform cuisine list (fixed taxonomy, not free-tagging — see
  // ux-parity-decisions). Drives the home cuisine rail + filtering. Values are
  // constrained in app code (CUISINE_TAGS in @fd/shared), not by an enum, so the
  // list can grow without a migration.
  cuisineTags String[]       @default([])
  createdAt DateTime         @default(now()) @db.Timestamptz()
  updatedAt DateTime         @updatedAt @db.Timestamptz()

  owner     User             @relation("RestaurantOwner", fields: [ownerId], references: [id])
  branches  Branch[]
  theme     RestaurantTheme?
  riders    Rider[]
  staff     UserRole[]
  payouts   Payout[]
  campaigns Campaign[]
  ratings   Rating[]
  sharedRiderPolicy SharedRiderPolicy?
  vouchers  Voucher[]

  @@map("restaurants")
}

model TaxProfile {
  id        String   @id @default(cuid())
  name      String
  rateBps   Int
  inclusive Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz()

  branches Branch[]

  @@map("tax_profiles")
}

model Branch {
  id                String   @id @default(cuid())
  restaurantId      String
  name              String
  addressText       String
  lat               Decimal  @db.Decimal(9, 6)
  lng               Decimal  @db.Decimal(9, 6)
  deliveryRadiusM   Int      @default(5000)
  minOrderMinor     Int      @default(0)
  deliveryFeeMinor  Int      @default(0)
  hoursJson         Json?
  taxProfileId      String
  activeMenuId      String?
  isAcceptingOrders Boolean  @default(true)
  // Busy mode (#46): extra minutes added to every prep ETA quote/accept default while
  // the kitchen is slammed, instead of pausing entirely. 0 = normal. Shown to customers
  // as an adjusted ETA on the quote side and pre-fills the vendor accept sheet.
  prepBufferMinutes Int      @default(0)
  // Google Places id for this physical location. Enables the venue-photo fallback
  // (tier 2 of the image pipeline, #50) when the restaurant has no uploaded hero.
  // Photo bytes are never stored — see services/placesPhoto.ts (Google ToS).
  googlePlaceId     String?
  createdAt         DateTime @default(now()) @db.Timestamptz()
  updatedAt         DateTime @updatedAt @db.Timestamptz()

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id])
  taxProfile TaxProfile      @relation(fields: [taxProfileId], references: [id])
  menus      Menu[]
  orders     Order[]
  sourceDocs MenuSourceDoc[]
  hours      BranchHours[]
  cancellationStat BranchCancellationStat?

  @@index([restaurantId])
  @@map("branches")
}

// Structured per-day opening hours (#19). Supersedes the ad-hoc Branch.hoursJson blob:
// one row per open window per day (a day may have several, e.g. a lunch + dinner split).
// dayOfWeek is a JS weekday (0 = Sunday … 6 = Saturday); minutes are since-midnight in
// PKT (UTC+5, no DST) to match branchHoursOpenState. A window with closeMinute <= openMinute
// spans midnight and spills into the next calendar day. A branch with NO rows is treated
// as always open (isOpenNow falls back to hoursJson, then to "open"). setBranchHours
// replaces the whole set transactionally, so there is no update/delete path for a single row.
model BranchHours {
  id          String @id @default(cuid())
  branchId    String
  dayOfWeek   Int
  openMinute  Int
  closeMinute Int

  branch Branch @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@map("branch_hours")
}

model RestaurantTheme {
  id              String     @id @default(cuid())
  restaurantId    String     @unique
  logoAssetId     String?
  heroAssetId     String?
  primaryColor    String     @default("#e11d48")
  accentColor     String     @default("#f59e0b")
  backgroundColor String     @default("#ffffff")
  textColor       String     @default("#171717")
  fontKey         String     @default("sans")
  cardStyle       CardStyle  @default(flat)
  heroEffect      HeroEffect @default(none)
  updatedAt       DateTime   @updatedAt @db.Timestamptz()

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id])
  logoAsset  MediaAsset? @relation("ThemeLogo", fields: [logoAssetId], references: [id])
  heroAsset  MediaAsset? @relation("ThemeHero", fields: [heroAssetId], references: [id])

  @@map("restaurant_themes")
}

// Lightweight admin-managed promo banner for the home carousel (ux-parity #36).
// Deliberately simple: an image + optional deep link + an active window. Full
// targeting/segmentation/campaign spend lives in the Campaigns engine (#22).
model HomeBanner {
  id        String    @id @default(cuid())
  title     String
  imageUrl  String
  linkHref  String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  startsAt  DateTime? @db.Timestamptz()
  endsAt    DateTime? @db.Timestamptz()
  createdAt DateTime  @default(now()) @db.Timestamptz()
  updatedAt DateTime  @updatedAt @db.Timestamptz()

  @@map("home_banners")
}

// ───────────────────────────── menus ─────────────────────────────

model Menu {
  id          String     @id @default(cuid())
  branchId    String
  version     Int
  status      MenuStatus @default(draft)
  layoutJson  Json?
  publishedAt DateTime?  @db.Timestamptz()
  createdAt   DateTime   @default(now()) @db.Timestamptz()

  branch     Branch          @relation(fields: [branchId], references: [id])
  categories MenuCategory[]
  modGroups  ModifierGroup[]
  combos     Combo[]

  @@unique([branchId, version])
  @@map("menus")
}

model MenuCategory {
  id                 String  @id @default(cuid())
  menuId             String
  name               String
  description        String?
  sortOrder          Int     @default(0)
  headerImageAssetId String?

  menu             Menu        @relation(fields: [menuId], references: [id])
  headerImageAsset MediaAsset? @relation("CategoryHeader", fields: [headerImageAssetId], references: [id])
  items            MenuItem[]

  @@index([menuId])
  @@map("menu_categories")
}

model MenuItem {
  id           String   @id @default(cuid())
  categoryId   String
  name         String
  description  String?
  priceMinor   Int
  // Optional "was" price for an item-level offer (#53). When set and strictly greater
  // than priceMinor, the customer sees a strike-through original + a "% off" badge, and
  // priceMinor is the charged (discounted) price. Never affects what the server charges —
  // quoteService always prices at priceMinor — it is display metadata only. Cleared to
  // null to end the offer.
  compareAtPriceMinor Int?
  isAvailable  Boolean  @default(true)
  // Timed 86 (#46): when a vendor marks an item unavailable "until end of day" from the
  // order board, this records when it should come back so the UI can surface it (and a
  // future sweep can auto-restock). null = 86'd until manually re-enabled, or available.
  unavailableUntil DateTime? @db.Timestamptz()
  imageAssetId String?
  badges       String[] @default([])
  sortOrder    Int      @default(0)

  category   MenuCategory            @relation(fields: [categoryId], references: [id])
  imageAsset MediaAsset?             @relation("ItemImage", fields: [imageAssetId], references: [id])
  modGroups  MenuItemModifierGroup[]
  comboItems ComboItem[]

  @@index([categoryId])
  @@map("menu_items")
}

// Combo / meal deal (#53): a bundle of menu items sold at a single fixed price
// ("Burger + Fries + Drink Rs 650"). Menu-scoped like ModifierGroup, so it is cloned
// on publish (cloneMenu) and lives only on the branch draft until published. v1 is
// FIXED bundles only (a set list of component items, each with a quantity); the richer
// "choose N from a group" semantics from the spec are deferred (see comboService TODO).
// Server prices a combo at priceMinor and freezes a component snapshot into the order,
// mirroring how MenuItem lines freeze menuSnapshotJson.
model Combo {
  id           String  @id @default(cuid())
  menuId       String
  name         String
  description  String?
  priceMinor   Int
  isAvailable  Boolean @default(true)
  imageAssetId String?
  sortOrder    Int     @default(0)

  menu       Menu        @relation(fields: [menuId], references: [id])
  imageAsset MediaAsset? @relation("ComboImage", fields: [imageAssetId], references: [id])
  items      ComboItem[]

  @@index([menuId])
  @@map("combos")
}

// One component of a combo: a menu item and how many of it the bundle includes.
model ComboItem {
  id         String @id @default(cuid())
  comboId    String
  menuItemId String
  qty        Int    @default(1)
  sortOrder  Int    @default(0)

  combo    Combo    @relation(fields: [comboId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([comboId])
  @@map("combo_items")
}

model ModifierGroup {
  id        String @id @default(cuid())
  menuId    String
  name      String
  minSelect Int    @default(0)
  maxSelect Int    @default(1)

  menu    Menu                    @relation(fields: [menuId], references: [id])
  options ModifierOption[]
  items   MenuItemModifierGroup[]

  @@index([menuId])
  @@map("modifier_groups")
}

model MenuItemModifierGroup {
  itemId    String
  groupId   String
  sortOrder Int    @default(0)

  item  MenuItem      @relation(fields: [itemId], references: [id])
  group ModifierGroup @relation(fields: [groupId], references: [id])

  @@id([itemId, groupId])
  @@map("menu_item_modifier_groups")
}

model ModifierOption {
  id              String  @id @default(cuid())
  groupId         String
  name            String
  priceDeltaMinor Int     @default(0)
  isAvailable     Boolean @default(true)
  sortOrder       Int     @default(0)

  group ModifierGroup @relation(fields: [groupId], references: [id])

  @@index([groupId])
  @@map("modifier_options")
}

model MenuSourceDoc {
  id        String           @id @default(cuid())
  branchId  String
  assetId   String
  kind      MenuSourceKind
  status    MenuSourceStatus @default(uploaded)
  createdAt DateTime         @default(now()) @db.Timestamptz()

  branch Branch     @relation(fields: [branchId], references: [id])
  asset  MediaAsset @relation(fields: [assetId], references: [id])

  @@index([branchId])
  @@map("menu_source_docs")
}

// ───────────────────────────── riders ─────────────────────────────

model Rider {
  id                 String            @id @default(cuid())
  userId             String            @unique
  riderType          RiderType         @default(restaurant)
  restaurantId       String?
  vehicleType        String?
  verificationStatus RiderVerification @default(pending)
  cashLimitMinor     Int               @default(1000000)
  // Shared-rider dispatch (#21). `sharedOptIn` is the per-rider consent to receive
  // shared-work offers from OTHER restaurants (defaults off — opt-in everywhere). In a
  // full build this is toggled per shift; the beta treats it as a persistent flag. Additive.
  sharedOptIn        Boolean           @default(false)
  // Trust score (0–100). Recomputed from delivery outcomes (see riderTrustService); feeds
  // the #21 dispatch scoring + COD cash rule, gates shared-offer eligibility (#28), and is
  // nudged down when #25 abuse signals fire (cash variance, GPS anomaly). Shared field.
  trustScore         Int               @default(70)
  // Auto-set true when rolling cash variance crosses the disable threshold; blocks the
  // rider from being assigned/offered COD orders until an admin clears it. (#25)
  codDisabled        Boolean           @default(false)
  // Onboarding requirements (differ by riderType — see riderVerificationService):
  //   restaurant rider: phone required, CNIC recommended.
  //   shared/independent: CNIC + photo + vehicle + plate REQUIRED. (#28)
  vehiclePlate       String?
  trainingCompleted  Boolean           @default(false)
  agreementAccepted  Boolean           @default(false)
  // When true the rider may receive shared/independent dispatch offers. Auto-disabled
  // when trustScore drops below the shared-eligibility threshold (breach risk). (#28)
  sharedModeEnabled  Boolean           @default(false)
  verifiedAt         DateTime?         @db.Timestamptz()
  rejectionReason    String?
  // Device binding (kickoff auth table, partial): the device id captured at OTP login.
  // A SIM/device change (new deviceId) should force re-verification — enforcement is a
  // TODO in the auth flow; this column stores the last-seen binding. (#28)
  boundDeviceId      String?
  createdAt          DateTime          @default(now()) @db.Timestamptz()

  user             User                  @relation(fields: [userId], references: [id])
  restaurant       Restaurant?           @relation(fields: [restaurantId], references: [id])
  availability     RiderAvailability?
  tasks            DeliveryTask[]
  offers           DeliveryOffer[]
  cashVariances    RiderCashVariance[]
  gpsAnomalies     GpsAnomaly[]
  verificationDocs RiderVerificationDoc[]

  @@index([restaurantId])
  @@index([verificationStatus])
  @@map("riders")
}

enum RiderDocKind {
  cnic_front
  cnic_back
  photo
  vehicle_registration
  license
}

// An uploaded verification document for a rider. Points at a finalized MediaAsset via
// assetId (same media pipeline as menu/theme/POD images). Reviewed in the admin queue.
model RiderVerificationDoc {
  id        String       @id @default(cuid())
  riderId   String
  kind      RiderDocKind
  assetId   String
  createdAt DateTime     @default(now()) @db.Timestamptz()

  rider Rider      @relation(fields: [riderId], references: [id])
  asset MediaAsset @relation("RiderDocAsset", fields: [assetId], references: [id])

  @@index([riderId])
  @@map("rider_verification_docs")
}

model RiderAvailability {
  id        String   @id @default(cuid())
  riderId   String   @unique
  isOnline  Boolean  @default(false)
  lat       Decimal? @db.Decimal(9, 6)
  lng       Decimal? @db.Decimal(9, 6)
  // Wall-clock time of the last location heartbeat (patchRiderLocation, #25). Distinct
  // from updatedAt (which also bumps on online/offline toggles) so GPS-anomaly speed math
  // uses the true delta between position pings, and staleness is measured off pings only.
  lastLocationAt DateTime? @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  rider Rider @relation(fields: [riderId], references: [id])

  @@map("rider_availability")
}

// ───────────────────────────── orders ─────────────────────────────

model Order {
  id                    String      @id @default(cuid())
  code                  String      @unique
  customerId            String
  branchId              String
  status                OrderStatus @default(pending_acceptance)
  idempotencyKey        String      @unique
  // Order-scoped pickup handoff PIN (#25). Shown to the customer + restaurant; the rider
  // must enter it to confirm they collected the right order (wrong-rider collection guard).
  // Additive — null on legacy orders, which the pickup gate treats as "no PIN required".
  pickupPin             String?
  addressSnapshotJson   Json
  contactPhone          String
  customerNote          String?
  subtotalMinor         Int
  deliveryFeeMinor      Int
  taxTotalMinor         Int
  platformFeeMinor      Int
  commissionMinor       Int
  // Optional rider tip (minor units), included in grandTotalMinor and — for COD — in
  // the cash the rider collects. There is no rider ledger split yet, so it is not
  // posted as a separate rider credit; see orderService TODO.
  tipAmount             Int         @default(0)
  // Whether to include cutlery/napkins with the order (sustainability opt-out).
  cutleryRequested      Boolean     @default(true)
  // Voucher discount applied at checkout (#52), in minor units. Subtracted from the
  // grand total. voucherId snapshots which voucher was redeemed (null if none). The
  // authoritative redemption row lives in VoucherRedemption (unique per order).
  discountMinor         Int         @default(0)
  voucherId             String?
  grandTotalMinor       Int
  commissionBpsSnapshot Int
  paymentMode           PaymentMode
  // Fulfillment (#54). `pickup` skips the radius check + delivery fee + rider assignment
  // and issues `pickupCode` for the customer to quote at the counter. `scheduledFor` is
  // set when the customer books a future slot (scheduled orders — groundwork; the
  // acceptance-SLA-from-scheduledFor sweeper change is a follow-up, see orderService).
  fulfillmentMode       FulfillmentMode @default(delivery)
  scheduledFor          DateTime?   @db.Timestamptz()
  pickupCode            String?
  acceptDeadlineAt      DateTime    @db.Timestamptz()
  prepEtaMinutes        Int?
  placedAt              DateTime    @default(now()) @db.Timestamptz()
  acceptedAt            DateTime?   @db.Timestamptz()
  readyAt               DateTime?   @db.Timestamptz()
  pickedUpAt            DateTime?   @db.Timestamptz()
  deliveredAt           DateTime?   @db.Timestamptz()
  cancelledAt           DateTime?   @db.Timestamptz()

  customer     User           @relation("CustomerOrders", fields: [customerId], references: [id])
  branch       Branch         @relation(fields: [branchId], references: [id])
  voucher      Voucher?       @relation(fields: [voucherId], references: [id])
  items        OrderItem[]
  events       OrderEvent[]
  deliveryTask DeliveryTask?
  payment      Payment?
  refunds      Refund[]
  cancellation Cancellation?
  rating       Rating?
  tickets      SupportTicket[]
  redemption   VoucherRedemption?

  @@index([branchId, status])
  @@index([customerId, placedAt])
  @@index([status, acceptDeadlineAt])
  @@map("orders")
}

model OrderItem {
  id               String @id @default(cuid())
  orderId          String
  menuSnapshotJson Json
  qty              Int
  unitPriceMinor   Int
  lineTotalMinor   Int
  notes            String?

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// Append-only: one row per status transition, written in the same tx as the transition.
model OrderEvent {
  id          String       @id @default(cuid())
  orderId     String
  fromStatus  OrderStatus?
  toStatus    OrderStatus
  actorUserId String?
  actorRole   String?
  reason      String?
  metaJson    Json?
  createdAt   DateTime     @default(now()) @db.Timestamptz()

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId, createdAt])
  @@map("order_events")
}

model DeliveryTask {
  id             String             @id @default(cuid())
  orderId        String             @unique
  riderId        String?
  status         DeliveryTaskStatus @default(unassigned)
  codAmountMinor Int                @default(0)
  // Offer→accept flow (swipe-to-accept). offeredAt is set when a task is dispatched
  // to a rider for acceptance; acceptedAt when they accept; declineReason captures the
  // last decline. All null on the legacy auto-assign path. Additive.
  offeredAt      DateTime?          @db.Timestamptz()
  acceptedAt     DateTime?          @db.Timestamptz()
  declineReason  String?
  // Optional proof-of-delivery photo captured at drop-off, uploaded via the shared
  // media flow and linked on riderDelivered. Additive.
  podMediaId     String?
  // Set when the rider enters the correct pickup PIN (#25). Gates riderPickedUp when the
  // order carries a PIN. Null = not yet verified (or legacy PIN-less order).
  pickupVerifiedAt DateTime?        @db.Timestamptz()
  assignedAt     DateTime?          @db.Timestamptz()
  createdAt      DateTime           @default(now()) @db.Timestamptz()

  order    Order           @relation(fields: [orderId], references: [id])
  rider    Rider?          @relation(fields: [riderId], references: [id])
  podMedia MediaAsset?     @relation("PodMedia", fields: [podMediaId], references: [id])
  events   DeliveryEvent[]
  offers   DeliveryOffer[]

  @@index([riderId, status])
  @@map("delivery_tasks")
}

// ───────────────────────────── shared-rider dispatch (#21) ─────────────────────────────

// Per-restaurant opt-in + guard-rails for lending idle rider capacity to nearby
// restaurants (the "lender" side). A branch with no policy row is treated as NOT sharing
// (opt-in everywhere). `vetoActive` is the per-shift kill switch the lender can flip to
// pause sharing without losing their configured limits. Additive; the lender's own orders
// always win, enforced in dispatchService, not here.
model SharedRiderPolicy {
  id                 String   @id @default(cuid())
  restaurantId       String   @unique
  sharingEnabled     Boolean  @default(false)
  vetoActive         Boolean  @default(false)
  // Max committed pre-pickup jobs a shared rider may hold (beta default 1; 2 only after
  // trust proven — enforced in the dispatch constraints, this is the ceiling).
  maxActiveJobs      Int      @default(1)
  // Pickup-distance ceiling to a new shared job, metres (dense-zone beta default 1.5 km).
  maxPickupMeters    Int      @default(1500)
  // Incremental delay a shared job may add to the committed customer, seconds (beta 5 min).
  maxIncrementalDelaySec Int  @default(300)
  // Minimum rider trustScore required before a shared rider may carry COD for this lender.
  codTrustThreshold  Int      @default(70)
  createdAt          DateTime @default(now()) @db.Timestamptz()
  updatedAt          DateTime @updatedAt @db.Timestamptz()

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@map("shared_rider_policies")
}

// A dispatch offer emitted to one candidate rider for one delivery task. Distinct from the
// DeliveryTask (which is the order's fulfilment record): several offers may be generated
// for a task — one per shortlisted rider — but at most one reaches `accepted`, and accepting
// locks the task to that rider. `matchedScore` is the dispatch score at generation time;
// `expiresAt` gives the 15–20s accept window; `rank` is the position in the shortlist.
// Every offer/accept/decline is recorded here for fairness analytics. Additive.
model DeliveryOffer {
  id           String              @id @default(cuid())
  taskId       String
  riderId      String
  status       DeliveryOfferStatus @default(pending)
  matchedScore Float
  rank         Int                 @default(0)
  // Constraint snapshot at generation (metres / seconds) — kept for analytics + audit.
  pickupMeters Int?
  incrementalDelaySec Int?
  isSharedRider Boolean            @default(false)
  expiresAt    DateTime            @db.Timestamptz()
  offeredAt    DateTime            @default(now()) @db.Timestamptz()
  respondedAt  DateTime?           @db.Timestamptz()
  declineReason String?

  task  DeliveryTask @relation(fields: [taskId], references: [id])
  rider Rider        @relation(fields: [riderId], references: [id])

  @@index([taskId, status])
  @@index([riderId, status])
  @@map("delivery_offers")
}

model DeliveryEvent {
  id          String            @id @default(cuid())
  taskId      String
  type        DeliveryEventType
  actorUserId String?
  lat         Decimal?          @db.Decimal(9, 6)
  lng         Decimal?          @db.Decimal(9, 6)
  note        String?
  createdAt   DateTime          @default(now()) @db.Timestamptz()

  task DeliveryTask @relation(fields: [taskId], references: [id])

  @@index([taskId, createdAt])
  @@map("delivery_events")
}

// Append-only per-drop cash-variance record (#25). One row per COD delivery where the
// rider's declared cash != the expected COD amount. varianceMinor is signed (negative =
// short remittance, positive = over). A rolling sum of |varianceMinor| over
// CASH_VARIANCE_WINDOW_DAYS drives the auto COD-disable. Written alongside the existing
// cash_mismatch SupportTicket, not instead of it.
model RiderCashVariance {
  id            String   @id @default(cuid())
  riderId       String
  orderId       String
  expectedMinor Int
  collectedMinor Int
  varianceMinor Int
  createdAt     DateTime @default(now()) @db.Timestamptz()

  rider Rider @relation(fields: [riderId], references: [id])

  @@index([riderId, createdAt])
  @@map("rider_cash_variances")
}

// Append-only GPS anomaly flag (#25). Written when two consecutive rider location
// heartbeats imply travel faster than GPS_ANOMALY_MAX_SPEED_KMH (teleport / mock-location).
// Informational + trust-score input; does not block delivery.
model GpsAnomaly {
  id          String   @id @default(cuid())
  riderId     String
  taskId      String?
  fromLat     Decimal  @db.Decimal(9, 6)
  fromLng     Decimal  @db.Decimal(9, 6)
  toLat       Decimal  @db.Decimal(9, 6)
  toLng       Decimal  @db.Decimal(9, 6)
  distanceM   Int
  elapsedSec  Int
  speedKmh    Int
  createdAt   DateTime @default(now()) @db.Timestamptz()

  rider Rider @relation(fields: [riderId], references: [id])

  @@index([riderId, createdAt])
  @@map("gps_anomalies")
}

// ───────────────────────────── payments & money ─────────────────────────────

// Gateway token only — a PAN never touches this database.
model PaymentMethod {
  id            String   @id @default(cuid())
  userId        String
  providerToken String   @unique
  brand         String
  last4         String
  expMonth      Int
  expYear       Int
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now()) @db.Timestamptz()

  user     User      @relation(fields: [userId], references: [id])
  payments Payment[]

  @@index([userId])
  @@map("payment_methods")
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  mode            PaymentMode
  status          PaymentStatus @default(pending)
  providerRef     String?
  paymentMethodId String?
  amountMinor     Int
  refundedMinor   Int           @default(0)
  capturedAt      DateTime?     @db.Timestamptz()
  createdAt       DateTime      @default(now()) @db.Timestamptz()

  order         Order          @relation(fields: [orderId], references: [id])
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  @@map("payments")
}

model Refund {
  id              String            @id @default(cuid())
  orderId         String
  status          RefundStatus      @default(refund_pending)
  amountMinor     Int
  destination     RefundDestination @default(card)
  reason          String
  decidedByUserId String?
  decidedAt       DateTime?         @db.Timestamptz()
  createdAt       DateTime          @default(now()) @db.Timestamptz()

  order   Order           @relation(fields: [orderId], references: [id])
  tickets SupportTicket[]

  @@index([orderId])
  @@map("refunds")
}

model Cancellation {
  id               String   @id @default(cuid())
  orderId          String   @unique
  cancelledBy      String
  reasonCode       String
  feeAssessedMinor Int      @default(0)
  // #30 cancellation & refund policy engine. Populated by policyService.evaluateCancellation.
  policyOutcome    String? // full_refund | partial_refund | fee_charged | no_charge | support_review
  faultParty       String? // customer | restaurant | rider | dispatch | platform | none
  refundMinor      Int? // amount refunded to customer (minor units); null on legacy rows
  policyNote       String? // human-readable rationale from the policy engine
  createdAt        DateTime @default(now()) @db.Timestamptz()

  order Order @relation(fields: [orderId], references: [id])

  @@map("cancellations")
}

// #30 ranking-penalty counters, keyed per branch. Incremented whenever a cancellation
// scenario carries fault against the branch (rejects, auto-expiry, wrong/missing item).
// Feeds browse ordering later; kept as a simple running tally for now.
model BranchCancellationStat {
  id            String   @id @default(cuid())
  branchId      String   @unique
  penaltyPoints Int      @default(0)
  rejectCount   Int      @default(0)
  expiredCount  Int      @default(0)
  faultCount    Int      @default(0)
  updatedAt     DateTime @updatedAt @db.Timestamptz()
  createdAt     DateTime @default(now()) @db.Timestamptz()

  branch Branch @relation(fields: [branchId], references: [id])

  @@map("branch_cancellation_stats")
}

// Double-entry ledger. Legs of one txId must balance (SUM(debit) == SUM(credit)),
// enforced by ledgerService — the only writer.
model LedgerAccount {
  id        String          @id @default(cuid())
  ownerType LedgerOwnerType
  ownerId   String?
  code      String          @unique
  createdAt DateTime        @default(now()) @db.Timestamptz()

  entries LedgerEntry[]

  @@index([ownerType, ownerId])
  @@map("ledger_accounts")
}

model LedgerEntry {
  id          String   @id @default(cuid())
  txId        String
  accountId   String
  debitMinor  Int      @default(0)
  creditMinor Int      @default(0)
  orderId     String?
  payoutId    String?
  refundId    String?
  memo        String
  createdAt   DateTime @default(now()) @db.Timestamptz()

  account LedgerAccount @relation(fields: [accountId], references: [id])

  @@index([txId])
  @@index([accountId, createdAt])
  @@map("ledger_entries")
}

model Payout {
  id           String       @id @default(cuid())
  restaurantId String
  periodStart  DateTime     @db.Timestamptz()
  periodEnd    DateTime     @db.Timestamptz()
  amountMinor  Int
