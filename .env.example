# Copy to .env at the repo root. All processes read this single file.
DATABASE_URL=postgresql://fd:fd@localhost:5455/fooddelivery
SESSION_SECRET=dev-secret-change-me-0000000000000000

# --- Collapsed mode (default) -------------------------------------------------
# The GraphQL API is mounted inside the web app at /api/graphql, so `pnpm --filter
# @fd/web dev` serves everything. Leave the two overrides below UNSET for this mode:
#   NEXT_PUBLIC_API_URL   -> defaults to the relative "/api/graphql"
#   OBJECT_STORE_BASE_URL -> defaults to "" (same-origin /files + /api/uploads)

# Local-disk object store (dev). On Vercel use /tmp/storage (ephemeral); swap to S3/R2 for
# durable storage.
STORAGE_DIR=./.storage

# Protects the /api/cron/* endpoints. Vercel Cron sends it as a Bearer token; external
# pingers pass it as ?secret=. Leave unset locally to keep the crons open.
# CRON_SECRET=change-me

# --- Standalone-API mode (optional) -------------------------------------------
# To run apps/api as its own server again, uncomment these so the web app targets it:
# API_PORT=4000
# WEB_ORIGIN=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:4000/graphql
# OBJECT_STORE_BASE_URL=http://localhost:4000

# --- Splitting the API onto its own origin (session cookie scope) -------------
# Only needed when the API runs on a different origin than the web app. Put both on
# sibling subdomains of ONE registrable domain (api.example.com + app.example.com) and
# set the cookie domain so the web edge proxy AND the API read the same session cookie.
# Use the BARE parent domain (no leading dot) — RFC 6265 scopes it to all subdomains.
# Genuinely cross-site origins (e.g. *.vercel.app + *.onrender.com) can't share a cookie
# and get blocked as third-party — use a custom domain instead.
# SESSION_COOKIE_DOMAIN=example.com
# SESSION_COOKIE_SAMESITE=lax     # lax is correct for the subdomain setup; "none" only
                                  # for true cross-site (forces Secure; often blocked).

# --- Realtime fan-out (#11/#26) -----------------------------------------------
# Set on the persistent API host so SSE subscriptions work across instances. Absent =
# in-memory pubsub (single-instance dev; the reason live SSE never pushed on Vercel).
# REDIS_URL=rediss://default:<token>@<name>.upstash.io:6379

# --- Object storage (#142) ----------------------------------------------------
# STORAGE_DRIVER=local (default, disk) or r2 (Cloudflare R2 / any S3-compatible bucket).
# When r2, all four R2_* vars are required; objects are read from R2_PUBLIC_BASE_URL.
# STORAGE_DRIVER=r2
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# R2_BUCKET=herald-uploads
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_PUBLIC_BASE_URL=https://cdn.heraldeats.app

# --- Menu OCR import (#177) ---------------------------------------------------
# Automatic transcription of photo/PDF menus into reviewable draft rows. Default "none"
# = OFF: previewMenuOcr returns an empty preview + a "connect an OCR provider" message,
# and CSV/manual import still work. A real driver (Google Vision / AWS Textract /
# Tesseract) is added in apps/api/src/services/menuOcr.ts and selected here — no UI
# change, since OCR rows reuse the CSV review pipeline.
# MENU_OCR_DRIVER=none

# --- Out-of-app notifications (#13) -------------------------------------------
# Every channel is OFF by default (free). A channel only sends when its flag is on AND
# its credentials below are present, so setting a flag without keys is a safe no-op.
# Flip these at launch — no code change needed.
# NOTIFY_WEBPUSH=off        # free; also set VAPID_* and NEXT_PUBLIC_VAPID_PUBLIC_KEY
# NOTIFY_EMAIL=off          # free tier; needs RESEND_API_KEY
# NOTIFY_WHATSAPP=off       # paid + Meta template approval; needs WHATSAPP_*
# NOTIFY_SMS=off            # paid; needs TWILIO_*

# Web push (VAPID). Generate a keypair once: `npx web-push generate-vapid-keys`.
# The public key must ALSO be exposed to the browser via NEXT_PUBLIC_VAPID_PUBLIC_KEY.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:ops@heraldeats.app
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Email (Resend REST API).
# RESEND_API_KEY=
# EMAIL_FROM=Herald Eats <orders@heraldeats.app>

# WhatsApp Cloud API (Meta).
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=

# SMS (Twilio).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+1xxxxxxxxxx

# Absolute web origin used to build deep links in outbound messages (email/SMS/WA
# can't use relative hrefs). Defaults to WEB_ORIGIN.
# PUBLIC_WEB_URL=https://heraldeats.vercel.app
