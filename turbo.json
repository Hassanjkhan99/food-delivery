{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URL", "SESSION_SECRET", "STORAGE_DIR", "CRON_SECRET", "NODE_ENV"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "src/generated/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "codegen": {
      "dependsOn": ["^build"],
      "outputs": ["src/graphql/generated/**", "schema.graphql"]
    }
  }
}
